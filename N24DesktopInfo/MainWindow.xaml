<Window x:Class="N24DesktopInfo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="N24 Desktop Info"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False"
        ResizeMode="NoResize"
        SizeToContent="Height"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Border x:Name="MainBorder"
            CornerRadius="8"
            Padding="18"
            SnapsToDevicePixels="True">
        <Border.Background>
            <SolidColorBrush x:Name="BgBrush" Color="#1a1a2e" Opacity="0.72" />
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black" />
        </Border.Effect>

        <StackPanel x:Name="ContentPanel">
            <!-- Title -->
            <TextBlock x:Name="TitleText"
                       FontWeight="Bold"
                       Margin="0,0,0,8" />

            <!-- Separator -->
            <Rectangle x:Name="TitleSeparator" Height="1" Margin="0,0,0,10"
                       HorizontalAlignment="Stretch" />

            <!-- Info Content -->
            <TextBlock x:Name="InfoText"
                       TextWrapping="NoWrap"
                       LineHeight="20"
                       LineStackingStrategy="BlockLineHeight" />

            <!-- Traffic Chart (dynamically shown/hidden) -->
            <Border x:Name="ChartBorder" Margin="0,2,0,0" Visibility="Collapsed"
                    CornerRadius="4" BorderThickness="1">
                <Grid>
                    <Canvas x:Name="ChartCanvas" ClipToBounds="True" />
                    <!-- Legend overlay top-right -->
                    <StackPanel x:Name="ChartLegend" 
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,4,6,0" />
                </Grid>
            </Border>

            <!-- Footer Separator -->
            <Rectangle x:Name="FooterSeparator" Height="1" Margin="0,10,0,8"
                       HorizontalAlignment="Stretch" />

            <!-- Footer -->
            <TextBlock x:Name="FooterText" Margin="0,0,0,0" />
        </StackPanel>
    </Border>
</Window>
