{
  "Position": {
    "X": -1,
    "Y": -1,
    "Anchor": "TopRight",
    "MarginTop": 5,
    "MarginRight": 5,
    "MarginBottom": 60,
    "MarginLeft": 30
  },
  "Display": {
    "FontFamily": "Cascadia Code Light",
    "FontSize": 12.5,
    "BackgroundOpacity": 0.10,
    "BackgroundColor": "#1a1a2e",
    "AccentColor": "#00d4aa",
    "LabelColor": "#e6f1ff",
    "ValueColor": "#e6f1ff",
    "WarningColor": "#ffb347",
    "CriticalColor": "#ff6b6b",
    "SeparatorColor": "#2d3561",
    "TitleColor": "#00d4aa",
    "BarFillColor": "#00d4aa",
    "BarEmptyColor": "#2d3561",
    "BarBorderColor": "#4a5080",
    "BarHeight": 15,
    "LabelWidth": 90,
    "ValueWidth": 210,
    "CornerRadius": 8,
    "Padding": 18,
    "Width": 340
  },
  "Uptime": {
    "Format": "{D} {TAGE}, {HH} Stunden {MM} Minuten"
  },
  "Refresh": {
    "IntervalSeconds": 1,
    "ExternalIpIntervalMinutes": 1440
  },
  "Sections": {
    "ShowHostname": true,
    "ShowOS": true,
    "ShowUptime": true,
    "ShowCPU": true,
    "ShowRAM": true,
    "ShowDisks": true,
    "ShowNetwork": true,
    "ShowExternalIP": true,
    "ShowTrafficText": true,
    "ShowTrafficChart": true,
    "ShowVersion": true
  },
  "Network": {
    "ExternalIpUrl": "https://api.ipify.org",
    "IgnoreAdapters": [ "Loopback", "vEthernet", "VMware", "VirtualBox", "Hyper-V" ]
  },
  "Disk": {
    "WarningPercent": 80,
    "CriticalPercent": 95,
    "OnlyFixedDrives": true
  },
  "Traffic": {
    "InColor": "#00d4aa",
    "OutColor": "#ff6b6b",
    "GridColor": "#2d3561",
    "BorderColor": "#4a5080",
    "LabelColor": "#8892b0",
    "ChartHeight": 60,
    "ChartSeconds": 60,
    "LineThickness": 1.5,
    "Unit": "auto",
    "EnableDebugLog": false
  }
}
